# Server
PORT=3000
NODE_ENV=development

# JWT (server-minted session tokens)
JWT_SECRET=change-me
JWT_ISSUER=rare-crypto-api
JWT_AUDIENCE=co.rarecrypto.app
JWT_EXPIRES_IN=1h

# Postgres
DATABASE_URL=postgres://user:pass@localhost:5432/rarecrypto

# Apple Sign In (fill after Developer enrollment)
APPLE_AUDIENCE_IOS=co.rarecrypto.app
APPLE_ISSUER=https://appleid.apple.com

# Feature flags
ENABLE_AUTH_DEV=true
